---
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GearCard from '../components/GearCard.astro';
import { imageMapByStem } from '../lib/images';

// Pull in every gear photo once, here, rather than inside each card. Photos are
// matched to items by filename — e.g. src/assets/gear/mac.jpg → id "mac". An
// item with no matching file simply gets `undefined` and the card shows a
// monogram, so missing photos never break the build.
const photoById = imageMapByStem(
  import.meta.glob<{ default: ImageMetadata }>(
    '/src/assets/gear/*.{jpg,jpeg,png,webp,avif}',
    { eager: true }
  )
);

const allGear = await getCollection('gear');

const edc = allGear.filter((item) => item.data.location === 'edc');
const personalCare = allGear.filter(
  (item) => item.data.location === 'personal-care'
);
const other = allGear.filter((item) => item.data.location === 'other');

const sections = [
  { title: 'EDC', items: edc },
  { title: 'Hygiene', items: personalCare },
  { title: 'Other', items: other },
];
---

<BaseLayout title="Gear · Andrew Ghosh" description="What I carry and what I own.">
  <h1 class="page-title">Possesions</h1>
  <p class="page-tagline">
    I'm a minimalist, so everything here had to earn its place.
  </p>

  <p>
    This is everything I own, outside my wardrobe (that's one place where minimalism doesn't apply).
  </p>

  <div class="gear-panel">
    {
      sections.map((section) => (
        <section class="gear-section">
          <div class="gear-section__head">
            <h2 class="gear-section__title">{section.title}</h2>
            <div class="gear-section__controls">
              <button
                class="gear-nav"
                type="button"
                data-gear-prev
                aria-label="Scroll left"
              >
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="15 18 9 12 15 6" />
                </svg>
              </button>
              <button
                class="gear-nav"
                type="button"
                data-gear-next
                aria-label="Scroll right"
              >
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </button>
            </div>
          </div>
          <div class="gear-row">
            {section.items.map((item) => (
              <GearCard
                name={item.data.name}
                link={item.data.link}
                photo={photoById.get(item.id)}
              />
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <p>
    You might be wondering:
  </p>

  <ul>
    <li>Kitchen stuff? Yahentamitsi Dining Hall.</li>
    <li>Exercise equipment? Eppley Rec Center.</li>
    <li>Fun, interesting, things? <a href="https://startupshell.org" target="_blank" rel="noopener noreferrer">Startup Shell</a>.</li>
  </ul>
</BaseLayout>

<script>
  // Each gear row scrolls horizontally via its prev/next buttons. The buttons
  // dim at the extremes once there's nothing left to scroll that way.

  // initGearCarousels re-runs after every navigation. The page DOM (and its
  // per-row click/scroll listeners) is replaced each time, so those tear down
  // with it — but `window` is not replaced. So instead of adding a fresh resize
  // listener per row on every visit (which would pile up and pin detached
  // nodes), register one resize listener here that calls into whatever rows are
  // current.
  let arrowUpdaters: Array<() => void> = [];
  window.addEventListener('resize', () => arrowUpdaters.forEach((fn) => fn()));

  function initGearCarousels() {
    arrowUpdaters = [];
    document.querySelectorAll<HTMLElement>('.gear-section').forEach((section) => {
      const row = section.querySelector<HTMLElement>('.gear-row');
      const prev = section.querySelector<HTMLButtonElement>('[data-gear-prev]');
      const next = section.querySelector<HTMLButtonElement>('[data-gear-next]');
      if (!row) return;

      const step = () => Math.max(row.clientWidth * 0.8, 200);
      prev?.addEventListener('click', () =>
        row.scrollBy({ left: -step(), behavior: 'smooth' })
      );
      next?.addEventListener('click', () =>
        row.scrollBy({ left: step(), behavior: 'smooth' })
      );

      // Both arrows stay visible, but dim (disable) at the extremes: the left
      // one when scrolled fully left, the right one when scrolled fully right.
      const updateArrows = () => {
        const max = row.scrollWidth - row.clientWidth;
        if (prev) prev.disabled = row.scrollLeft <= 1;
        if (next) next.disabled = max <= 1 || row.scrollLeft >= max - 1;
      };
      row.addEventListener('scroll', updateArrows, { passive: true });
      updateArrows();
      arrowUpdaters.push(updateArrows);
    });
  }

  // Runs on first load and after every client-side (View Transitions) navigation.
  document.addEventListener('astro:page-load', initGearCarousels);
</script>
