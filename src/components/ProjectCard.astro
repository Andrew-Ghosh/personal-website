---
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';

interface Props {
  title: string;
  summary: string;
  link?: string;
  repo?: string;
  tech: string[];
  cover?: ImageMetadata;
}

const { title, summary, link, repo, tech, cover } = Astro.props;

// When a project has a link the whole card becomes an <a> (new tab); otherwise
// a plain <article>. Same markup either way, just a different wrapper element.
const Wrapper = link ? 'a' : 'article';
const wrapperProps = link
  ? { href: link, target: '_blank', rel: 'noopener noreferrer', 'aria-label': title }
  : {};
---

{
  cover ? (
    /* Showcase variant: eyebrow label + a screenshot framed like a browser
       window, peeking up from the bottom of a soft panel. */
    <Wrapper class="project project--showcase" {...wrapperProps}>
      <div class="project__head">
        <span class="project__eyebrow">{title}</span>
        <span class="project__arrow">
          <svg
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="7" y1="17" x2="17" y2="7" />
            <polyline points="7 7 17 7 17 17" />
          </svg>
        </span>
      </div>
      <div class="project__frame">
        <Picture
          src={cover}
          formats={['avif', 'webp']}
          alt={`${title} screenshot`}
          width={1000}
          densities={[1, 2]}
          loading="lazy"
        />
      </div>
    </Wrapper>
  ) : (
    /* Text variant: clean editorial card. */
    <article class="project project--text">
      <h3 class="project__title">{link ? <a href={link} target="_blank" rel="noopener noreferrer">{title}</a> : title}</h3>
      <p class="project__summary">{summary}</p>
      {tech.length > 0 && (
        <ul class="project__tech">
          {tech.map((t) => (
            <li>{t}</li>
          ))}
        </ul>
      )}
      {repo && <a class="project__repo" href={repo} target="_blank" rel="noopener noreferrer">View code repo →</a>}
    </article>
  )
}
