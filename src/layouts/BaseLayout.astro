---
import { ClientRouter } from 'astro:transitions';
import Rail from '../components/Sidebar.astro';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {/* Resolve the theme (stored choice, else OS preference) and apply it before
       the first paint to avoid a flash of the wrong mode. We also re-apply it
       across client-side (View Transitions) navigations: the incoming
       server-rendered document has no data-theme, so we stamp it on *before* the
       swap copies <html> attributes over — without this the attribute is briefly
       dropped and the page (most visibly the sun/moon toggle) flickers to light
       and back. */}
    <script is:inline>
      (function () {
        function currentTheme() {
          return (
            localStorage.getItem('theme') ||
            (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
          );
        }
        document.documentElement.dataset.theme = currentTheme();
        document.addEventListener('astro:before-swap', function (e) {
          e.newDocument.documentElement.dataset.theme = currentTheme();
        });
        document.addEventListener('astro:after-swap', function () {
          document.documentElement.dataset.theme = currentTheme();
        });
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <Rail />
    <main class="content">
      <div class="content-inner">
        <slot />
      </div>
    </main>
  </body>
</html>
